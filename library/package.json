{
  "name": "t3d-lib",
  "version": "3.0.0",
  "license": "GPL-3.0",
  "main": "build/T3D-node.cjs",
  "module": "build/T3D.mjs",
  "exports": {
    ".": {
      "require": "./build/T3D-node.cjs",
      "import": "./build/T3D.mjs",
      "default": "./build/T3D.mjs"
    }
  },
  "types": "src/T3DLib.ts",
  "scripts": {
    "build": "rollup -c",
    "version": "npm run build; git add build",
    "lint:check": "eslint src",
    "lint:fix": "eslint src --fix",
    "format:fix": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "test": "node --test ./test/*.test.mjs"
  },
  "dependencies": {
    "t3d-parser": "*",
    "three": "0.184.0",
    "vblob": "1.0.2",
    "web-worker": "1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^26.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-typescript": "^11.1.6",
    "@types/three": "0.184.0",
    "@typescript-eslint/eslint-plugin": "8.5.0",
    "@typescript-eslint/parser": "8.5.0",
    "rollup": "4.21.3",
    "tslib": "2.7.0",
    "typescript": "5.5.4"
  },
  "prettier": {
    "useTabs": false,
    "trailingComma": "es5",
    "tabWidth": 2,
    "printWidth": 120
  }
}
