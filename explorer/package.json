{
  "name": "t3d-explorer",
  "version": "3.0.0",
  "description": "Modern Guild Wars 2 map explorer",
  "type": "module",
  "author": "Tyria 3D contributors",
  "license": "GPL-3.0",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "build": "vite build",
    "preview": "vite preview",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:fix": "prettier --write ./src ./test",
    "format:check": "prettier --check ./src ./test",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "t3d-lib": "*",
    "t3d-parser": "*",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@types/node": "20.16.5",
    "@types/three": "0.184.0",
    "@vitest/coverage-v8": "2.1.2",
    "jsdom": "25.0.1",
    "typescript": "5.5.4",
    "typescript-eslint": "8.5.0",
    "vite": "6.4.2",
    "vitest": "2.1.2"
  }
}
